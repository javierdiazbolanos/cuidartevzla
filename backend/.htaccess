# Cuídarte Venezuela - Configuración de Seguridad de Servidor Apache (.htaccess)
# Terremotos de Venezuela - Junio de 2026

# Evitar listado de directorios
Options -Indexes

# Establecer juego de caracteres predeterminado
AddDefaultCharset UTF-8

# Denegar acceso por defecto a cualquier archivo PHP
<FilesMatch "\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Permitir acceso exclusivamente a los puntos de entrada autorizados de la API
<FilesMatch "^(pacientes|pacientes_lote|deduplicate|sync|sync2|sync_mini|hospitales|medicamentos|transporte|stats|edificios|run_homogenize_names|run_migracion_dedup|backup_db|run_dedup_existing|procesar_con_llm|test_openrouter|migrate_varchar_200|migrate_carga_log|carga_log|superuser_status|debug_headers|migrate_initial_carga|test_dedup|export_db)\.php$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Allow from all
    </IfModule>
</FilesMatch>

# Ocultar archivos de configuración ocultos o del sistema
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
